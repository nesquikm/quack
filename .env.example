# Quack — environment variables read by src/shared/env.ts.
# Copy to `.env` (gitignored) and edit before the first `docker compose up`.

# HTTP port the Bun server binds to inside the container.
PORT=7474

# Plaintext bootstrap token. Consumed only on first boot, when the users table is
# empty: the server mints the initial admin user/project/membership/token and
# IGNORES this var on every subsequent boot. Generate one with:
#   openssl rand -base64 32
# MUST NOT be committed.
QUACK_BOOTSTRAP_TOKEN=

# Directory holding auth.sqlite (and, eventually, embedded graph data).
# Inside the container this points at the `quack-data` named volume.
QUACK_DATA_DIR=/data

# Cheap-model API key (OpenAI-compatible bearer). Optional in M2; required from
# M3 when the extractor runs. Same redaction policy as Authorization headers —
# never persisted to auth.sqlite, never written to logs. MUST NOT be committed.
QUACK_MODEL_API_KEY=

# Base URL of the OpenAI-compatible endpoint. Optional in M2; required from M3.
# Examples:
#   https://api.anthropic.com/v1
#   https://api.openai.com/v1
#   http://localhost:11434/v1
QUACK_MODEL_BASE_URL=
