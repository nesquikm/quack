# Quack — environment variables read by src/shared/env.ts.
# Copy to `.env` (gitignored) and edit before the first `docker compose up`.

# HTTP port the Bun server binds to inside the container.
PORT=7474

# Bind host for the Bun HTTP server. Allowed values: 127.0.0.1, 0.0.0.0.
# Default 127.0.0.1 — loopback-only on the developer machine. Inside the
# Docker image this is overridden to 0.0.0.0 (the Dockerfile sets it) so
# that compose.yml's `127.0.0.1:7474:7474` host port mapping can forward
# traffic to the container. The loopback-only guarantee for the container
# is enforced by the host port mapping, not by the in-container bind.
QUACK_BIND_HOST=127.0.0.1

# Plaintext bootstrap token. Consumed only on first boot, when the users table is
# empty: the server mints the initial admin user/project/membership/token and
# IGNORES this var on every subsequent boot. Generate one with:
#   openssl rand -base64 32
# MUST NOT be committed.
QUACK_BOOTSTRAP_TOKEN=

# Directory holding auth.sqlite (and, eventually, embedded graph data).
# Inside the container this points at the `quack-data` named volume.
QUACK_DATA_DIR=/data

# Cheap-model API key (OpenAI-compatible bearer). Optional in M2; required from
# M3 when the extractor runs. Same redaction policy as Authorization headers —
# never persisted to auth.sqlite, never written to logs. MUST NOT be committed.
QUACK_MODEL_API_KEY=

# Base URL of the OpenAI-compatible endpoint. Optional in M2; required from M3.
# Examples:
#   https://api.anthropic.com/v1
#   https://api.openai.com/v1
#   http://localhost:11434/v1
#   https://generativelanguage.googleapis.com/v1beta/openai/   (Google Gemini)
QUACK_MODEL_BASE_URL=

# Model name passed to the OpenAI-compatible endpoint. Defaults to `gpt-4o-mini`
# when unset. Pick a cheap, fast model — the extractor and the ask_memory loop
# are the only callers. Examples:
#   gpt-4o-mini                  (OpenAI)
#   claude-haiku-4-5             (Anthropic)
#   gemini-3-flash-preview       (Google Gemini, via the base URL above)
#   gemini-2.5-flash-lite        (Google Gemini, cheapest)
QUACK_MODEL_NAME=

# Neo4j Community 5.x — graph DB connection (M3, FR-SFQDXR).
# QUACK_NEO4J_URL defaults to `bolt://graphdb:7687` (the Compose service name);
# override for non-Docker dev pointing at a local Neo4j install.
QUACK_NEO4J_URL=bolt://graphdb:7687
QUACK_NEO4J_USER=neo4j
# REQUIRED. Generate with: openssl rand -base64 32. MUST NOT be committed.
QUACK_NEO4J_PASSWORD=
